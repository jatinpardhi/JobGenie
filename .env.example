# --- Core ---
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# --- Database (SQLite by default for zero-install dev) ---
DATABASE_URL="file:./dev.db"

# --- Redis (BullMQ) ---
# Install Memurai (free Redis for Windows): winget install Memurai.MemuraiDeveloper
REDIS_URL=redis://localhost:6379

# --- AI ---
# Default: local Ollama (free, runs on your machine).
# Install Ollama from https://ollama.com, then: `ollama pull llama3.1`
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.1
# To use OpenAI instead:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini
# To use Groq:
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=gsk_...
#   OPENAI_MODEL=llama-3.3-70b-versatile

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Automation ---
PLAYWRIGHT_HEADLESS=true
HUMAN_APPROVAL_MODE=true
DAILY_APPLICATION_LIMIT=25
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) JobGenieBot/0.1"

# --- Storage (resume uploads) ---
UPLOAD_DIR=./uploads
